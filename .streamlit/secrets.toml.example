[cookie]
expiry_days = 30
key = "mtc_validator_secret_key_2024"
name = "mtc_validator_auth"

# OCR and API Keys for PDF extraction
MISTRAL_API_KEY = "your_mistral_api_key_here"  # Get from https://console.mistral.ai/
IMGBB_API_KEY = "your_imgbb_api_key_here"      # Get from https://api.imgbb.com/ (free register)


