# Streamlit Secrets - Example Format
# For LOCAL development with 'streamlit run', copy this to secrets.toml
# DO NOT commit secrets.toml with real passwords to version control
# 
# For Streamlit Cloud, use the web interface:
# Settings → Secrets → Paste this format

[credentials]
[credentials.usernames]

[credentials.usernames.piloto_empresa1]
email = "contacto@empresa1.com"
first_name = "Piloto"
last_name = "Empresa1"
password = "piloto2024"

[credentials.usernames.admin]
email = "hola@adaga.tech"
first_name = "Adrian"
last_name = "Admin"
password = "admin2024"

[credentials.usernames.tester]
email = "test@mtcvalidator.com"
